--// Cache
local buying = {}
local randomTargets = {}

--// Buy Function
local function spamBuy(itemId)

	if buying[itemId] then
		return
	end

	buying[itemId] = true

	for thread = 1, BUY_THREADS do
		task.spawn(function()

			for i = 1, MAX_BUYS do

				if not ENABLED then
					break
				end

				pcall(function()
					BuyRF:InvokeServer(itemId)
				end)

				for _ = 1, 4 do
					RunService.Heartbeat:Wait()
				end
			end

		end)
	end
end

--// Handle Item
local function handleItem(item)

	if not ENABLED or not item then
		return
	end

	local itemId = item.Name

	if not itemId then
		return
	end

	local quantity = tonumber(item:GetAttribute("totalQuantity"))
	local sold = tonumber(item:GetAttribute("quantitySold"))

	if quantity and quantity >= SKIP_QUANTITY then
		return
	end

	-- 4 random sold targets بدون تكرار
	if quantity and sold then

		if not randomTargets[itemId] then

			local used = {}
			local targets = {}

			while #targets < 4 do

				local num = math.random(2, quantity)

				if not used[num] then
					used[num] = true
					table.insert(targets, num)
				end
			end

			table.sort(targets)

			randomTargets[itemId] = targets
		end

		local allowed = false

		for _, target in ipairs(randomTargets[itemId]) do
			if sold >= target then
				allowed = true
				break
			end
		end

		if not allowed then
			return
		end
	end

	local releaseTime = tonumber(item:GetAttribute("releaseTime"))

	if releaseTime then

		local diff = releaseTime - tick()

		if diff > 0 then

			task.wait(math.max(diff - 0.02, 0))

			while tick() < releaseTime do
				RunService.Heartbeat:Wait()
			end
		end
	end

	spamBuy(itemId)
end

--// New Items
Marketplace.ChildAdded:Connect(handleItem)

--// Refreshed Items
ItemRefreshed.OnClientEvent:Connect(function(itemId)

	-- fix Instance/string issue
	if typeof(itemId) == "Instance" then
		itemId = itemId.Name
	end

	local item = Marketplace:FindFirstChild(itemId)

	if not item then
		repeat
			RunService.Heartbeat:Wait()
			item = Marketplace:FindFirstChild(itemId)
		until item or not ENABLED
	end

	if item then
		handleItem(item)
	end
end)

--// Buy newest item on join
task.spawn(function()

	local newest
	local newestTime = -math.huge

	for _, item in ipairs(Marketplace:GetChildren()) do
		local rt = tonumber(item:GetAttribute("releaseTime"))

		if rt and rt > newestTime then
			newestTime = rt
			newest = item
		end
	end

	if newest then
		handleItem(newest)
	end
end)

