-- 🔥 BUY LOGIC
local function autoBuyItem(item)
	if not snipingEnabled then return end
	if activeItems[item] then return end
	activeItems[item] = true

	task.spawn(function()
		if not item or not item:IsA("Instance") then return end

		local itemId = item.Name
		local releaseTime = tonumber(item:GetAttribute("releaseTime"))
		local quantity = tonumber(item:GetAttribute("totalQuantity"))

		if quantity and quantity >= 100 then
			activeItems[item] = nil
			return
		end

		-- ⏳ انتظار release
		if releaseTime and tick() < releaseTime then
			while tick() < releaseTime and snipingEnabled do
				task.wait(0.01)
			end
		end

		local bought = 0
		local fails = 0

		while bought < 4 and snipingEnabled do
			local success, result = pcall(function()
				return BuyRF:InvokeServer(itemId)
			end)

			if success and result == true then
				bought += 1
				fails = 0

				if DEBUG then
					print("✅ REAL BUY:", itemId, "Attempt:", bought)
				end

				task.wait(1.3)

			elseif success and result == "SoldOut" then
				if DEBUG then
					print("❌ SOLD OUT:", itemId)
				end
				break

			else
				fails += 1

				if fails >= 20 then
					task.wait(0.05)
					fails = 0
				else
					task.wait(0.01)
				end
			end
		end

		activeItems[item] = nil
	end)
end

-- 📦 ChildAdded
Marketplace.ChildAdded:Connect(function(item)
	autoBuyItem(item)
end)

-- 🔄 ItemRefreshed
ItemRefreshed.OnClientEvent:Connect(function(data)
	local item

	if typeof(data) == "Instance" then
		item = data
	else
		item = Marketplace:FindFirstChild(data)
	end

	if not item then
		task.wait(0.05)
		if typeof(data) == "string" then
			item = Marketplace:FindFirstChild(data)
		end
	end

	if item then
		autoBuyItem(item)
	end
end)

-- 🟢 Buy last item on join
local lastItem, lastTime = nil, -math.huge
for _, item in ipairs(Marketplace:GetChildren()) do
	local rt = tonumber(item:GetAttribute("releaseTime"))
	if rt and rt > lastTime then
		lastItem = item
		lastTime = rt
	end
end

if lastItem then
	autoBuyItem(lastItem)
end

